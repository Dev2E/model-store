# ===============================================
# CONFIGURAÇÃO VELLENIA STORE - VARIÁVEIS DE AMBIENTE
# ===============================================
# COPIE este arquivo para .env.local e preencha com seus valores
# ⚠️ NUNCA commitar .env.local no Git!

# ===============================================
# 🔐 SUPABASE - Banco de Dados & Autenticação
# ===============================================
# Obter em: https://supabase.com → Project Settings → API

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave Anônima (SEGURA para usar no frontend)
# ⚠️ Esta é a chave ANON (public), é seguro expor no frontend
# Se expor a SERVICE_KEY = seria um risco de segurança
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===============================================
# 💳 MERCADO PAGO - Pagamentos
# ===============================================
# Obter em: https://www.mercadopago.com.br/developers/panel
# Escolha: PÚBLICO KEY (não use SECRET KEY aqui!)

# Chave Pública do Mercado Pago (segura para frontend)
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR_xxxxxxxxxxxxxx

# ===============================================
# 🔄 MODO TESTE vs PRODUÇÃO
# ===============================================
# CRÍTICO: Deve corresponder com suas credenciais acima!

# true = TESTES (use credenciais de SANDBOX)
# false = PRODUÇÃO (use credenciais de PRODUÇÃO)
VITE_SANDBOX_MODE=true

# ===============================================
# 🤖 RECAPTCHA V3 (Opcional - Anti-Bot)
# ===============================================
# Obter em: Google Admin Console → reCAPTCHA → v3

# Site key V3 (segura para frontend)
VITE_RECAPTCHA_KEY=seu_site_key_aqui

# ===============================================
# 🌐 FRONTEND - URLs
# ===============================================

# URL base do seu frontend (para email links, etc)
# DEV: http://localhost:5173
# PROD: https://seu-dominio.com
VITE_FRONTEND_URL=http://localhost:5173

# ===============================================
# 🔧 AMBIENTE & DEBUG
# ===============================================

# Ambiente: dev, staging, production
NODE_ENV=development

# Debug mode (log extra em console)
VITE_DEBUG=false

# Habilitar HTTPS em desenvolvimento
# VITE_HTTPS=true  (descomente para ativar)


# Se já commitou por acaso:
# 1. Revogue o token imediatamente
# 2. Use git-filter-branch ou BFG Repo-Cleaner
# 3. Force push com cuidado
